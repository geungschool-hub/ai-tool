{
  "rules": {
    "vocab": {
      "config":   { ".read": "auth != null", ".write": "auth != null" },
      "words":    { ".read": "auth != null", ".write": "auth != null" },
      "levels":   { ".read": "auth != null", ".write": "auth != null" },
      "seasons":  { ".read": "auth != null", ".write": "auth != null" },
      "classGoal":{ ".read": "auth != null", ".write": "auth != null" },
      "cheers":   { ".read": "auth != null", ".write": "auth != null" },
      "daily":    { ".read": "auth != null", ".write": "auth != null" },
      "levelLog": { ".read": "auth != null", ".write": "auth != null" },
      "scoreLog": { ".read": "auth != null", ".write": "auth != null" },
      "resetLog": { ".read": "auth != null", ".write": "auth != null" },
      "students": {
        ".read": "auth != null",
        ".indexOn": ["studentId"],
        "$uid": { ".write": "auth != null" }
      },
      "progress": {
        ".read": "auth != null",
        "$uid": { ".write": "auth != null" }
      }
    },
    "examGoals": {
      ".read": true,
      ".write": true
    },
    "reportPlans": {
      ".read": true,
      ".write": true
    },
    "vote": {
      ".read": true,
      "rooms": {
        "$rid": {
          ".write": "!data.exists()",
          "teacherHash": { ".write": "!data.exists()" },
          "name":        { ".write": "!data.exists()" },
          "current":     { ".write": true },
          "elections": {
            ".write": "!newData.exists()",
            "$eid": {
              ".write": "!data.exists() || !newData.exists()",
              "status": {
                ".write": true,
                ".validate": "newData.isString() && (newData.val() == 'open' || newData.val() == 'closed' || newData.val() == 'counting' || newData.val() == 'done')"
              },
              "result": { ".write": true },
              "ballots": {
                "$bid": { ".write": "!data.exists() || !newData.exists()" }
              },
              "voters": {
                "$sid": { ".write": "!data.exists() || !newData.exists()" }
              }
            }
          }
        }
      }
    }
  }
}
