{
  "rules": {
    "quizMeta": {
      ".read": "auth != null",
      "$quizId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['title','totalQuestions'])"
      }
    },
    "quizzes": {
      ".read": "auth != null",
      "$quizId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['title','questions'])"
      }
    },
    "quizBackups": {
      ".read": "auth != null",
      "$quizId": {
        ".write": "auth != null"
      }
    },
    "results": {
      ".read": "auth != null",
      "$quizId": {
        ".write": "auth != null && newData.val() == null",
        ".indexOn": ["studentId", "timestamp"],
        "$recordId": {
          ".write": "auth != null && !data.exists() && newData.val() != null",
          ".validate": "newData.hasChildren(['studentId','name','score','total','timestamp']) && newData.child('studentId').isString() && newData.child('name').isString() && newData.child('score').isNumber() && newData.child('total').isNumber() && newData.child('timestamp').isString()"
        }
      }
    },
    "students": {
      ".read": "auth != null",
      ".indexOn": ["studentId"],
      "$uid": {
        ".write": "auth != null",
        ".validate": "newData.val() == null || newData.hasChildren(['studentId','name'])"
      }
    },
    "progress": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null"
      }
    }
  }
}
